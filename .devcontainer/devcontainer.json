// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "Podnebnik",

    "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

    // Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/dotnet:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:2": {
            "version": "24"
        },
		"ghcr.io/stuartleeks/dev-container-features/shell-history:0": {},
		"ghcr.io/esimkowitz/devcontainer-features/claude-code-persistence:1": {}
	},

    // Finalize container setup when a dev container is created.
	"onCreateCommand": "sudo apt-get update && sudo apt-get install -y fish git pipenv libvips-dev",

    // A command to run each time the container is successfully started.
    "postStartCommand": "npx yarn install",

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [8000, 8080],

	// Configure tool-specific properties.
	"customizations": {
        "vscode": {
			"extensions": [
				"ms-python.python",
				"georgewfraser.fsharp-language-server",
				"Ionide.Ionide-fsharp",
				"Anthropic.claude-code"
			]
		}
    }

	// Uncomment to connect as an existing user other than the container default. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "devcontainer"
}
